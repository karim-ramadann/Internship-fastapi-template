# Makefile for Runtime Infrastructure
# This is a convenience wrapper - use the main Makefile at ../Makefile for full features

.PHONY: help

help:
	@echo "This is a convenience Makefile for the runtime directory."
	@echo "Please use the main Makefile from the parent directory:"
	@echo ""
	@echo "  cd .. && make help"
	@echo ""
	@echo "Or run commands directly:"
	@echo ""
	@echo "  Development:"
	@echo "    cd .. && make init-dev"
	@echo "    cd .. && make plan-dev"
	@echo "    cd .. && make apply-dev"
	@echo ""
	@echo "  Staging:"
	@echo "    cd .. && make init-staging"
	@echo "    cd .. && make plan-staging"
	@echo "    cd .. && make apply-staging"
	@echo ""
	@echo "  Production:"
	@echo "    cd .. && make init-production"
	@echo "    cd .. && make plan-production"
	@echo "    cd .. && make apply-production"
